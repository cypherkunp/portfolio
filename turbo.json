{
  "$schema": "https://v2-8-12.turborepo.dev/schema.json",
  "globalEnv": ["NEXT_PUBLIC_APP_URL", "GITHUB_ACCESS_TOKEN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "start": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
